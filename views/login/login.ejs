<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Iniciar Sesion</title>
</head>
<body>
    <h1>Iniciar Sesion</h1>
    <a href="/">Regresar al dashboard</a>
    <br><br>

    <form action="/login" method="POST">

        Correo: <input type="email" name="correo" required>
        <br><br>

        Contrasena: <input type="password" name="contrasena" required>
        <br><br>

        <button type="submit">Iniciar sesion</button>

    </form>
</body>
</html>