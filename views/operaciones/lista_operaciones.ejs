<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Operaciones</title>

</head>
<body>
    <div class="container">
        <h1>Operaciones</h1>
        
        <div class="search-row">
            <input type="text" placeholder="Buscar por...">
            <select>
                <option>Todos los tipos</option>
                <option>Deposito</option>
                <option>Retiro</option>
                <option>Disposición</option>
                <option>Pago</option>
            </select>
            <select>
                <option>Ultimo mes</option>
                <option>Ultimos 3 meses</option>
                <option>Ultimo año</option>
            </select>
            <button class="btn">+ Registrar</button>
        </div>

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Cliente</th>
                    <th>Contrato</th>
                    <th>Producto</th>
                    <th>Tipo</th>
                    <th>Monto</th>
                    <th>Moneda</th>
                    <th>Fecha</th>
                    <th>Estatus</th>
                </tr>
            </thead>
            <tbody>
                <!-- Aqui llamaremos a la tabla cuando la tengamos -->
            </tbody>
        </table>
    </div>
</body>
</html>
