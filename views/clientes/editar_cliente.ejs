<!DOCTYPE html>
<html>
<head>
    <%- include('./../css.ejs') %>
</head>
<body>
    <div class="container">

        <h4><%= title %></h4>

        <!-- regresar a la lista-->
        <a href="/clientes/lista">Volver a la lista</a>

        <br><br>

        <!-- editar cliente -->
        <form action="/clientes/editar" method="POST">

            <!-- id para saber el cliente -->
            <input type="hidden" name="idCliente" value="<%= cliente.idCliente %>">

            <div class="input-field">
                <input type="text" name="nombre" id="nombre" value="<%= cliente.nombre %>" required>
                <label class="active" for="nombre">Nombre o Razon Social</label>
            </div>

            <div class="input-field">
                <input type="text" name="rfc" id="rfc" value="<%= cliente.rfc %>" required>
                <label class="active" for="rfc">RFC</label>
            </div>

            <div class="input-field">
                <input type="email" name="correo" id="correo" value="<%= cliente.correo %>">
                <label class="active" for="correo">Correo electronico</label>
            </div>

            <div class="input-field">
                <input type="text" name="telefono" id="telefono" value="<%= cliente.telefono %>">
                <label class="active" for="telefono">Telefono</label>
            </div>

            <!-- fisico/moral-->
            <p>Tipo de persona</p>
            <select name="tipoPersona" class="browser-default">
                <option value="Fisica" <%= cliente.tipoPersona === 'Fisica' ? 'selected' : '' %>>Persona Fisica</option>
                <option value="Moral"  <%= cliente.tipoPersona === 'Moral'  ? 'selected' : '' %>>Persona Moral</option>
            </select>

            <br><br>

            <!-- PEP-->
            <p>
                <label>
                    <input type="checkbox" name="esPep" value="true" <%= cliente.esPep ? 'checked' : '' %>>
                    <span>Es Persona Expuesta Politicamente (PEP)</span>
                </label>
            </p>

            <br>

            <button type="submit" class="btn">Guardar Cambios</button>

        </form>

    </div>
    <%- include('./../scripts.ejs') %>
</body>
</html>
