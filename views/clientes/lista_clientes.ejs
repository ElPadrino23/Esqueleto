<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clientes</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
            background: #f5f5f5;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border: 1px solid #ddd;
        }
        h1 {
            font-size: 24px;
            margin-bottom: 20px;
            font-weight: normal;
        }
        .search-row {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }
        .search-row input {
            flex: 1;
            padding: 8px 12px;
            border: 1px solid #ccc;
            font-size: 14px;
        }
        .btn {
            padding: 8px 16px;
            background: #333;
            color: white;
            border: none;
            cursor: pointer;
            font-size: 14px;
        }
        .btn:hover {
            background: #555;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border: 1px solid #ddd;
        }
        th {
            background: #f9f9f9;
            font-weight: normal;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Clientes</h1>
        
        <div class="search-row">
            <input type="text" placeholder="Realizar busqueda">
            <button class="btn">Filtrar</button>
            <a href="/clientes/expediente" class="btn" style="text-decoration: none; display: inline-block;">Nuevo cliente</a>
        </div>
        <!-- en caso de necesitar agregar mas datos a la tabla, se agrega en la parte de abajo con <th> -->
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre / Razon social</th>
                    <th>RFC</th>
                    <th>Tipo</th>
                    <th>Riesgo</th>
                    <th>PEP</th>
                    <th>Docs</th>
                </tr>
            </thead>
            <tbody>
                <!-- en esta parte se agregara la taba con datos -->
            </tbody>
        </table>
    </div>
</body>
</html>