<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alertas</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
            background: #f5f5f5;
        }
        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border: 1px solid #ddd;
        }
        h1 {
            font-size: 24px;
            margin-bottom: 20px;
            font-weight: normal;
        }
        .tabs {
            display: flex;
            gap: 0;
            border-bottom: 1px solid #ddd;
            margin-bottom: 20px;
        }
        .tab {
            padding: 10px 20px;
            border: 1px solid #ddd;
            border-bottom: none;
            background: white;
            cursor: pointer;
            font-size: 14px;
        }
        .tab.active {
            background: #f9f9f9;
            font-weight: bold;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border: 1px solid #ddd;
        }
        th {
            background: #f9f9f9;
            font-weight: normal;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Alertas</h1>
        <!-- Aqui tenemos que agregar la que dijo la oficial de cumplimiento, espero las notas para modificarlo-->
        <div class="tabs">
            <div class="tab active">Pendientes</div>
            <div class="tab">revision</div>
            <div class="tab">Resueltas</div>
            <div class="tab">Historial</div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Cliente</th>
                    <th>Operación</th>
                    <th>Regla disparada</th>
                    <th>Nivel</th>
                    <th>Fecha</th>
                    <th>Responsable</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <!-- Aqui se realizara el vaciado de datos o la llamada de datos en su defecto -->
            </tbody>
        </table>
    </div>
</body>
</html>
